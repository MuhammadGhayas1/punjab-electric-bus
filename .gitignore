# .gitignore for Punjab Electric Bus
# Next.js (App Router) + Expo + JavaScript + Vercel
# Generated: 2026-03-01

# Next.js
.next/
out/
.next/cache/

# Vercel
.vercel/

# Dependencies
node_modules/

# npm
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Package lockfiles (optional - keep if you want to version them)
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# Expo
.expo/
.expo-shared/
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.orig.*

# Android
android/app/build/
android/.gradle/
android/local.properties

# iOS (if ever added)
ios/build/
ios/Pods/

# Metro/EAS
web-build/
dist/
*.apk
*.aab
*.ipa
*.app

# Environment variables (keep .env.example tracked)
.env*.local
.env*.production
*.env

# Do NOT ignore .env.example - it should be committed
!.env.example

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.fuse_hidden*

# Editor
.idea/
.vscode/
*.swp
*.swo
*.swn
*.bak
*.tmp
*.temp

# ESLint/Prettier cache
.eslintcache
.prettiercache

# Build outputs
build/
dist/
coverage/
.nyc_output/

# TypeScript (if used later)
*.tsbuildinfo

# Keystores & signing keys (Expo/Android)
*.keystore
*.jks
upload-keystore.jks
android/app/*.keystore

# Expo credentials
expo.json
eas.json
*.p12
*.mobileprovision

# User config
*.local.js
config.local.js

# Keep these files even if they match patterns above
!.gitkeep
!public/downloads/.gitkeep
